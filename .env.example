# Environment Variables for Multilingual Nigerian Blog
# Copy this file to .env.local (never commit .env.local to git)

# --------------------------------------------------------
# DATABASE
# For local development: SQLite (zero setup)
# For production (Vercel + Neon): switch to PostgreSQL URL
# --------------------------------------------------------
DATABASE_URL="file:./dev.db"

# --------------------------------------------------------
# GOOGLE CLOUD TRANSLATION API KEY (v2 REST)
# Get this from: https://console.cloud.google.com/apis/credentials
# Enable: Cloud Translation API v2
# --------------------------------------------------------
GOOGLE_TRANSLATE_API_KEY="YOUR_GOOGLE_TRANSLATE_API_KEY_HERE"

# --------------------------------------------------------
# ADMIN SECURITY (Simple secret for Phase 2 CMS routes)
# --------------------------------------------------------
ADMIN_SECRET="change-this-to-a-secure-random-string"
